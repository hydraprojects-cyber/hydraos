###> HydraOS ###

# Local runtime state (never versioned)
.hydralocal/
HydraLocal/

# Logs
*.log
logs/
System/logs/

# Temporary files
temp/
tmp/
*.tmp

# OS-specific junk
Thumbs.db
.DS_Store

# IDEs (users may use any IDE)
.vscode/
.idea/

# Build artifacts (C# / .NET)
bin/
obj/

# Backup files
*.bak
*.old
*.orig

# Sensitive files (if ever created)
*.key
*.pem

